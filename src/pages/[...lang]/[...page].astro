---
import type { GetStaticPaths } from "astro";
import Pagination from "../../components/control/Pagination.astro";
import PostPage from "../../components/PostPage.astro";
import {
	DEFAULT_LANG,
	PAGE_SIZE,
	SUPPORTED_LANG,
} from "../../constants/constants";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../../utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allPaths = [];

	for (const lang of SUPPORTED_LANG) {
		const postsForLang = await getSortedPosts(lang);
		const langParam = lang === DEFAULT_LANG ? undefined : lang;

		const paginatedPages = paginate(postsForLang, {
			params: { lang: langParam },
			pageSize: PAGE_SIZE,
			props: { lang },
		});

		allPaths.push(...paginatedPages);
	}

	return allPaths;
	// const allBlogPosts = await getSortedPosts();
	// return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page, lang } = Astro.props;

const len = page.data.length;
---

<MainGridLayout lang={lang}>
    <PostPage page={page} lang={lang}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
</MainGridLayout>