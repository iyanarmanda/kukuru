---
import { getCollection, render } from "astro:content";
import Comment from "@components/comment/index.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Markdown from "@components/misc/Markdown.astro";
import { DEFAULT_LANG, SUPPORTED_LANG } from "@constants/constants";
import { normalizeLangTag } from "@utils/content-utils";
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

const { lang = DEFAULT_LANG } = Astro.props;

export const getStaticPaths = (async () => {
	return SUPPORTED_LANG.map((lang) => ({
		params: {
			lang: lang === DEFAULT_LANG ? undefined : lang,
		},
		props: { lang },
	}));
}) satisfies GetStaticPaths;

const allSpecEntries = await getCollection("spec");
const targetSlug = `${lang}/friends`;

let friendsPost = allSpecEntries.find(
	(entry) => normalizeLangTag(entry.id) === normalizeLangTag(targetSlug),
);

if (!friendsPost) {
	const defaultSlug = `${DEFAULT_LANG}/friends`;
	friendsPost = allSpecEntries.find(
		(entry) =>
			normalizeLangTag(entry.id) === normalizeLangTag(defaultSlug) ||
			normalizeLangTag(entry.id) === "friends",
	);
}

if (!friendsPost) {
	throw new Error("Friends page content not found");
}

const { Content } = await render(friendsPost);

const friendsEntries = await getCollection("friends");
---

<MainGridLayout title={i18n(I18nKey.friends, lang)} description={i18n(I18nKey.friends, lang)} lang={lang}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32 mb-4">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-8 my-4">

        {friendsEntries.map((entry) => (
          <div class="flex flex-nowrap items-stretch h-28 gap-4 rounded-(--radius-large)">
            <div class="w-28 h-28 shrink-0 rounded-lg overflow-hidden bg-zinc-200 dark:bg-zinc-900">
              <ImageWrapper src={entry.data.siteIcon} alt={entry.data.siteTitle}></ImageWrapper>
            </div>
            <div class="grow w-full">
              <div class="font-bold transition text-lg text-neutral-900 dark:text-neutral-100 mb-1">{entry.data.siteTitle}</div>
              <div class="text-50 text-sm font-medium">{entry.data.siteDesc}</div>
            </div>
            <a href={entry.data.siteUrl} target="_blank" rel="noopener noreferrer"
              class="flex btn-regular w-[3.25rem] rounded-lg bg-(--enter-btn-bg) hover:bg-(--enter-btn-bg-hover) active:bg-(--enter-btn-bg-active) active:scale-95"
            >
              <Icon name="material-symbols:chevron-right" class="transition text-(--primary) text-4xl mx-auto" />
            </a>
          </div>
        ))}

      </div>

      <Markdown class="mt-8">
        <Content/>
      </Markdown>
    </div>
  </div>

  <Comment lang={lang} />

</MainGridLayout>

