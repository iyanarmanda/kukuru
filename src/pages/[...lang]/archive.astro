---
import ArchivePanel from "@components/ArchivePanel.svelte";
import { DEFAULT_LANG, SUPPORTED_LANG } from "@constants/constants";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import type { GetStaticPaths } from "astro";
import { getSortedPostsList } from "../../utils/content-utils";

export const getStaticPaths = (async () => {
	return SUPPORTED_LANG.map((lang) => ({
		params: {
			lang: lang === DEFAULT_LANG ? undefined : lang,
		},
		props: { lang },
	}));
}) satisfies GetStaticPaths;

const { lang } = Astro.props;
const sortedPostsList = await getSortedPostsList(lang);
---

<MainGridLayout title={i18n(I18nKey.archive, lang)} lang={lang}>
    <!-- @ts-expect-error ts(9013) - (temporary solutions) -->
    <ArchivePanel sortedPosts={sortedPostsList} lang={lang} client:only="svelte"></ArchivePanel>
</MainGridLayout>

